{
  "name": "smartq",
  "packageManager": "npm@11.6.2",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=web --filter=api",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "dev:patient": "turbo run dev --filter=patient"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^2.8.20",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.577.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
